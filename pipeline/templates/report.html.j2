<!DOCTYPE html>
<html lang="en" data-theme="auto">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ header.app_name }} — Review Analysis · {{ header.run_id }}</title>
  <style>{{ pico_css | safe }}</style>
  <style>
    /* Layout / nav */
    body { padding-top: 0; }
    nav.top {
      position: sticky; top: 0; z-index: 100;
      background: var(--pico-background-color);
      border-bottom: 1px solid var(--pico-muted-border-color);
      padding: 0.6rem 1rem;
      margin-bottom: 1.5rem;
    }
    nav.top ul {
      display: flex; gap: 1rem; flex-wrap: wrap;
      margin: 0; padding: 0; list-style: none;
      align-items: baseline;
    }
    nav.top a { font-size: 0.9rem; text-decoration: none; }
    nav.top a:hover { text-decoration: underline; }
    nav.top .app-name { font-weight: 600; margin-right: 1rem; }
    /* Push the toggle LI to the far right of the nav. margin-left:auto has
       to live on the flex item (the LI), not the button inside it. */
    nav.top li.nav-end { margin-left: auto; }

    /* Explicit color override. Pico does something subtle: inside button
       scope it redefines --pico-color itself to --pico-primary-inverse
       (white in light theme). So `color: var(--pico-color)` resolves to
       white inside a button regardless of theme — invisible on our
       transparent background.
       Fix: use `inherit` so the button takes color from the surrounding
       nav/body chain, where --pico-color still has its proper value. */
    nav.top .theme-toggle {
      cursor: pointer;
      background: transparent;
      color: inherit;
      border: 1px solid var(--pico-muted-border-color);
      padding: 0.2rem 0.7rem;
      border-radius: 4px;
      font-size: 0.85rem;
      font-weight: 500;
      line-height: 1.4;
    }
    nav.top .theme-toggle:hover {
      background: var(--pico-secondary-background, rgba(0,0,0,0.05));
      border-color: currentColor;
      color: inherit;
    }
    nav.top .theme-toggle:focus-visible {
      outline: 2px solid var(--pico-primary, #3b82f6);
      outline-offset: 2px;
    }

    /* Stat cards */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0.8rem; margin: 1rem 0;
    }
    .stat-card {
      padding: 0.9rem 1rem;
      border: 1px solid var(--pico-muted-border-color);
      border-radius: var(--pico-border-radius);
    }
    .stat-card .value {
      font-size: 1.6rem; font-weight: 600; display: block; line-height: 1.2;
    }
    .stat-card .label {
      color: var(--pico-muted-color); font-size: 0.8rem;
      text-transform: uppercase; letter-spacing: 0.04em;
    }

    /* Stacked sentiment bar */
    .stacked-bar {
      display: flex; height: 1.6rem; border-radius: 4px; overflow: hidden;
      margin: 0.5rem 0; font-size: 0.8rem; color: white;
    }
    .stacked-bar > div {
      display: flex; align-items: center; justify-content: center;
      padding: 0 0.4rem; min-width: 0; white-space: nowrap;
    }

    /* Issue cards */
    .issue-card {
      border: 1px solid var(--pico-muted-border-color);
      border-radius: var(--pico-border-radius);
      padding: 1.5rem; margin-bottom: 1.5rem;
      background: var(--pico-card-background-color, var(--pico-background-color));
    }
    .issue-card > h3 { margin-top: 0; margin-bottom: 0.2rem; }
    .issue-card .subtitle {
      color: var(--pico-muted-color);
      font-style: italic; font-size: 0.95rem;
      margin-bottom: 0.6rem;
    }
    .stats-row {
      display: flex; gap: 1.5rem; flex-wrap: wrap;
      color: var(--pico-muted-color); font-size: 0.95rem;
      margin-bottom: 1rem;
    }
    .stats-row strong { color: var(--pico-color); }
    .issue-card h4 {
      margin: 1.2rem 0 0.5rem; font-size: 0.95rem;
      text-transform: uppercase; letter-spacing: 0.04em;
      color: var(--pico-muted-color);
    }
    .issue-card .sparkline-wrap {
      height: 90px; position: relative; margin: 0.5rem 0;
    }

    /* Pills — high-contrast in both themes (was hard to read against
       Pico's secondary-background grey) */
    .pill {
      display: inline-block;
      background: #dbeafe;       /* blue-100 */
      color: #1e3a8a;            /* blue-900 — strong contrast on light bg */
      border: 1px solid #93c5fd; /* blue-300 — gentle outline */
      padding: 0.22rem 0.7rem;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 500;
      margin: 0.15rem 0.15rem 0.15rem 0;
      white-space: nowrap;
    }
    [data-theme="dark"] .pill {
      background: #1e3a8a;       /* blue-900 */
      color: #dbeafe;            /* blue-100 */
      border-color: #3b82f6;     /* blue-500 */
    }
    /* Auto-theme (no explicit data-theme attribute on html) */
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) .pill {
        background: #1e3a8a;
        color: #dbeafe;
        border-color: #3b82f6;
      }
    }

    /* Run Delta — compact "stable" state (Phase X). When nothing changed,
       the section collapses to a single line so it doesn't claim the same
       visual real estate as the buckets-and-lists rich state. */
    section#delta.stable {
      padding: 0.6rem 1rem;
      border-left: 3px solid #5cb85c;
      background: rgba(92, 184, 92, 0.05);
      border-radius: var(--pico-border-radius);
      margin: 1rem 0 1.5rem;
    }
    .stable-line { margin: 0; line-height: 1.6; }
    .stable-line .badge {
      display: inline-block;
      padding: 0.1rem 0.55rem;
      font-size: 0.8rem;
      font-weight: 500;
      border-radius: 999px;
      margin: 0 0.3rem;
    }
    .stable-line .badge.stable {
      background: #5cb85c; color: white;
    }
    .stable-line .muted {
      color: var(--pico-muted-color);
    }
    [data-theme="dark"] section#delta.stable {
      background: rgba(92, 184, 92, 0.1);
    }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) section#delta.stable {
        background: rgba(92, 184, 92, 0.1);
      }
    }

    /* Run delta */
    .delta-bucket {
      padding: 1rem 1.2rem; border-radius: var(--pico-border-radius);
      margin-bottom: 1rem; border: 1px solid var(--pico-muted-border-color);
      border-left-width: 4px;
    }
    .delta-bucket.escalating { border-left-color: #d9534f; }
    .delta-bucket.improving  { border-left-color: #5cb85c; }
    .delta-bucket.new        { border-left-color: #5bc0de; }
    .delta-bucket.resolved   { border-left-color: #888; }
    .delta-bucket h4 { margin-top: 0; margin-bottom: 0.6rem; }
    .delta-bucket ul { margin: 0; padding-left: 1.2rem; }
    .delta-bucket li { margin: 0.3rem 0; }
    .delta-bucket .change {
      font-weight: 600; font-variant-numeric: tabular-nums;
    }
    .delta-bucket.escalating .change { color: #d9534f; }
    .delta-bucket.improving  .change { color: #5cb85c; }

    /* Sortable tables */
    .sortable-table th { cursor: pointer; user-select: none; }
    .sortable-table th:hover { background: var(--pico-secondary-background, rgba(0,0,0,0.05)); }
    .sortable-table th::after { content: " ↕"; opacity: 0.3; font-size: 0.8em; }
    .sortable-table th.sort-asc::after { content: " ↑"; opacity: 1; }
    .sortable-table th.sort-desc::after { content: " ↓"; opacity: 1; }

    /* Trend indicators in the priority leaderboard (Phase X) */
    .trend { font-size: 0.85rem; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .trend-up      { color: #d9534f; font-weight: 600; }
    .trend-down    { color: #5cb85c; font-weight: 600; }
    .trend-new     { color: #5bc0de; font-weight: 600; }
    .trend-stable  { color: var(--pico-muted-color); }
    .trend-none    { color: var(--pico-muted-color); }

    /* ABSA bars */
    .absa-bar-row {
      display: grid; grid-template-columns: 8rem 1fr 4rem;
      gap: 0.5rem; align-items: center; margin: 0.3rem 0;
      font-size: 0.9rem;
    }
    .absa-bar {
      height: 1.2rem; border-radius: 3px;
      display: flex; align-items: center;
      padding: 0 0.4rem; color: white; font-size: 0.8rem;
    }
    .absa-bar.loved   { background: #5cb85c; }
    .absa-bar.hated   { background: #d9534f; }

    /* Aspect index filter input */
    .filter-input {
      max-width: 320px; margin-bottom: 0.8rem;
    }

    /* Footer (Phase IX: condensed one-line stats) */
    footer {
      margin-top: 2rem; padding-top: 1rem;
      border-top: 1px solid var(--pico-muted-border-color);
      color: var(--pico-muted-color); font-size: 0.9rem;
    }
    footer.by-the-numbers p {
      margin: 0; line-height: 1.5;
    }
    footer.by-the-numbers strong {
      color: var(--pico-color);
      text-transform: uppercase;
      font-size: 0.8em;
      letter-spacing: 0.06em;
      margin-right: 0.4rem;
    }

    /* Section narrative — one-sentence LLM lead under a question heading
       in the Detailed Analysis area (Phase IX). */
    .section-narrative {
      color: var(--pico-color);
      line-height: 1.5;
      margin: 0.4rem 0 1rem;
      max-width: 70ch;
    }
    .section-narrative strong {
      color: #1e3a8a;
    }
    [data-theme="dark"] .section-narrative strong {
      color: #93c5fd;
    }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) .section-narrative strong {
        color: #93c5fd;
      }
    }

    /* Compact code spans for run IDs */
    code { font-size: 0.85em; }

    /* Phase VII editorial pass — lead-paragraph styling */
    p.pitch {
      font-size: 1.1rem; font-weight: 500;
      color: var(--pico-color);
      margin: 0.4rem 0 0.6rem;
      max-width: 70ch;
    }
    p.meta {
      color: var(--pico-muted-color); font-size: 0.9rem;
      margin: 0 0 1.5rem;
    }
    p.narrative {
      font-size: 1.05rem; line-height: 1.5;
      margin: 1rem 0 1rem; max-width: 70ch;
    }
    .stat-grid.ribbon {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.6rem; margin-bottom: 2rem;
    }
    .stat-grid.ribbon .stat-card .value {
      font-size: 2rem; font-variant-numeric: tabular-nums;
    }

    /* Detailed-analysis divider — visually demotes everything below */
    hr.detailed-divider {
      margin: 3rem 0 1rem;
      border: 0; border-top: 1px solid var(--pico-muted-border-color);
    }
    section#detailed > h2 {
      color: var(--pico-muted-color); font-size: 1.3rem;
      margin-top: 0.5rem;
    }
    section#detailed { opacity: 0.95; }
    section#detailed h2:not(:first-child),
    section#detailed h3 {
      color: var(--pico-color); font-size: 1.1rem;
      margin-top: 2rem;
    }

    /* Show-more expander for issues 4-5 */
    details.more-issues > summary {
      cursor: pointer; padding: 0.6rem 1rem;
      background: var(--pico-secondary-background, rgba(0,0,0,0.04));
      border-radius: var(--pico-border-radius);
      font-weight: 500; margin: 1rem 0;
    }
    details.more-issues > summary:hover {
      background: var(--pico-muted-border-color);
    }

    /* Key Takeaways section (Phase VIII) — the "so what?" layer that
       connects the data to action. Visually weighty: this is the report's
       thesis, evidence below. */
    section#takeaways {
      background: var(--pico-card-background-color, #f8fafc);
      border-left: 4px solid #3b82f6;
      border-radius: var(--pico-border-radius);
      padding: 1.2rem 1.5rem;
      margin: 1.5rem 0 2rem;
    }
    section#takeaways h2 {
      margin-top: 0; margin-bottom: 0.6rem;
      font-size: 1.2rem;
      color: var(--pico-color);
    }
    section#takeaways .takeaways-list {
      margin: 0; padding-left: 1.4rem;
    }
    section#takeaways .takeaways-list li {
      margin: 0.55rem 0; line-height: 1.5;
      color: var(--pico-color);
    }
    section#takeaways .takeaways-list li strong {
      color: #1e3a8a;  /* match the pill color so the "what to do" reads */
    }
    [data-theme="dark"] section#takeaways {
      background: rgba(59, 130, 246, 0.08);
    }
    [data-theme="dark"] section#takeaways .takeaways-list li strong {
      color: #93c5fd;
    }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) section#takeaways {
        background: rgba(59, 130, 246, 0.08);
      }
      html:not([data-theme="light"]) section#takeaways .takeaways-list li strong {
        color: #93c5fd;
      }
    }

    /* Editorial-pass card layout — quieter, more story-shaped (Phase VII v2) */
    .card-stats {
      font-size: 0.95rem; color: var(--pico-muted-color);
      margin-bottom: 1.2rem;
    }
    .card-stats .big-number {
      font-size: 1.8rem; font-weight: 600;
      color: var(--pico-color);
      margin-right: 0.6rem;
      font-variant-numeric: tabular-nums;
    }
    .card-stats .big-number small {
      font-size: 0.6em; font-weight: 400; color: var(--pico-muted-color);
      margin-left: 0.2rem;
    }
    .card-stats .sep {
      margin: 0 0.7rem; color: var(--pico-muted-border-color);
    }
    .sparkline-caption {
      font-size: 0.85rem; color: var(--pico-muted-color);
      margin: 0.2rem 0 1.2rem; font-style: italic;
    }
    /* Endpoint axis labels: start date flush left, end date flush right
       under the sparkline. Lighter visual weight than a full 12-label axis. */
    .sparkline-axis {
      display: flex; justify-content: space-between;
      font-size: 0.75rem; color: var(--pico-muted-color);
      margin: -0.2rem 0 1.2rem; padding: 0 0.1rem;
      font-variant-numeric: tabular-nums;
    }
    .quotes {
      margin: 1.2rem 0;
    }
    .quotes-intro {
      font-size: 0.9rem; color: var(--pico-muted-color);
      text-transform: uppercase; letter-spacing: 0.06em;
      margin-bottom: 0.4rem;
    }
    .quotes blockquote {
      margin: 0.4rem 0; padding: 0.5rem 0.9rem;
      border-left: 3px solid var(--pico-muted-border-color);
      background: rgba(0, 0, 0, 0.02);
      font-style: normal; color: var(--pico-color);
      font-size: 0.95rem; line-height: 1.45;
    }
    [data-theme="dark"] .quotes blockquote {
      background: rgba(255, 255, 255, 0.03);
    }
    .metrics-footer {
      margin-top: 1.2rem; padding-top: 1rem;
      border-top: 1px solid var(--pico-muted-border-color);
      font-size: 0.9rem; color: var(--pico-muted-color);
    }
    .metrics-footer .metric-row {
      margin: 0.5rem 0; display: flex; flex-wrap: wrap;
      align-items: center; gap: 0.4rem;
    }
    .metrics-footer .metric-label {
      font-weight: 600; color: var(--pico-color);
      min-width: 7rem; text-transform: lowercase;
      font-variant: small-caps;
    }
    .metrics-footer .split-bar {
      flex: 1; min-width: 200px;
    }
  </style>
</head>
<body>
<nav class="top">
  <ul>
    <li class="app-name">{{ header.app_name }}</li>
    {% if takeaways.bullets %}<li><a href="#takeaways">Takeaways</a></li>{% endif %}
    {% if not run_delta.omitted %}<li><a href="#delta">Run Delta</a></li>{% endif %}
    <li><a href="#priority">Priority Issues</a></li>
    <li><a href="#detailed">Detailed analysis</a></li>
    <li class="nav-end"><button class="theme-toggle" onclick="toggleTheme()">Theme</button></li>
  </ul>
</nav>

<main class="container">
  <header>
    <h1>Review Analysis Report — {{ header.app_name }}</h1>
    <p class="pitch">{{ elevator_pitch }}</p>
    <p class="meta">{{ "{:,}".format(header.review_count) }} reviews · generated {{ header.generated_at }} · run <code>{{ header.run_id }}</code></p>
  </header>

  <!-- Run summary: narrative + 4-stat ribbon -->
  <section id="run-summary">
    <p class="narrative">{{ run_summary.narrative }}</p>
    <div class="stat-grid ribbon">
      <div class="stat-card">
        <span class="value">{{ "{:,}".format(run_summary.ribbon.reviews) }}</span>
        <span class="label">reviews</span>
      </div>
      <div class="stat-card">
        <span class="value">{% if run_summary.ribbon.escalating is none %}—{% else %}{{ run_summary.ribbon.escalating }}{% endif %}</span>
        <span class="label">escalating</span>
      </div>
      <div class="stat-card">
        <span class="value">{% if run_summary.ribbon.new is none %}—{% else %}{{ run_summary.ribbon.new }}{% endif %}</span>
        <span class="label">new</span>
      </div>
      <div class="stat-card">
        <span class="value">{% if run_summary.ribbon.resolved is none %}—{% else %}{{ run_summary.ribbon.resolved }}{% endif %}</span>
        <span class="label">resolved</span>
      </div>
    </div>
  </section>

  <!-- Key takeaways — the "so what?" layer (Phase VIII). LLM-synthesized
       3-5 actionable bullets, leading the report so readers see the thesis
       before the evidence. Section omits entirely on missing API key /
       LLM error, so the rest of the report is unaffected. -->
  {% if takeaways.bullets %}
  <section id="takeaways">
    <h2>Key takeaways</h2>
    <ul class="takeaways-list">
      {% for bullet in takeaways.bullets %}
      <li>{{ bullet | bold_md_to_html | safe }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <!-- Run Delta — promoted to lead-of-evidence position (Phase VII) since
       it's the most valuable answer the report gives. Renders even on
       first runs (with a baseline placeholder) so the section's existence
       isn't a surprise. -->
  {% if not run_delta.omitted %}
    {% set is_stable = not run_delta.first_run and not (run_delta.escalating or run_delta.improving or run_delta.new or run_delta.resolved) %}
  <section id="delta"{% if is_stable %} class="stable"{% endif %}>
    {% if is_stable %}
    {# Compact one-line state when nothing changed. Doesn't claim full
       section real estate on every "no changes" re-run. #}
    <p class="stable-line">
      <strong>Run Delta —</strong>
      <span class="badge stable">stable</span>
      <span class="muted">no significant changes vs prior run <code>{{ run_delta.prior_run_id }}</code></span>
    </p>
    {% else %}
    <h2>Run Delta</h2>
    {% if run_delta.first_run %}
    <p><em>No prior run on file for this app — this is the baseline. The next run will compare against this snapshot.</em></p>
    {% else %}
    <p>Compared to prior run <code>{{ run_delta.prior_run_id }}</code>. Issues that grew, shrank, appeared, or disappeared since then.</p>

    {% if run_delta.escalating %}
    <div class="delta-bucket escalating">
      <h4>Escalating (>20% increase)</h4>
      <ul>
      {% for e in run_delta.escalating %}
        <li>{{ e.label }} — {{ e.prior_count }} → {{ e.current_count }} <span class="change">+{{ "%.0f"|format(e.pct_change) }}%</span></li>
      {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if run_delta.improving %}
    <div class="delta-bucket improving">
      <h4>Improving (>20% decrease)</h4>
      <ul>
      {% for e in run_delta.improving %}
        <li>{{ e.label }} — {{ e.prior_count }} → {{ e.current_count }} <span class="change">{{ "%.0f"|format(e.pct_change) }}%</span></li>
      {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if run_delta.new %}
    <div class="delta-bucket new">
      <h4>New (no prior match)</h4>
      <ul>
      {% for e in run_delta.new %}
        <li>{{ e.label }} — {{ e.current_count }} reviews this run</li>
      {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if run_delta.resolved %}
    <div class="delta-bucket resolved">
      <h4>Resolved (no current match)</h4>
      <ul>
      {% for e in run_delta.resolved %}
        <li>{{ e.label }} — was {{ e.prior_count }} reviews last run</li>
      {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% endif %}{# closes first_run / has-changes #}
    {% endif %}{# closes is_stable / not-stable #}
  </section>
  {% endif %}

  <!-- Priority Issues — top 3 cards inline, 4-5 inside an expander. The
       leaderboard table still lists all of them so nothing's hidden, just
       prioritized. -->
  <section id="priority">
    <h2>Priority Issues</h2>
    <p>Negative-leaning clusters ranked by composite priority — weighted by volume, severity, urgency, and intense-emotion share (anger / disgust / fear).</p>

    {% if issues %}
    <table class="sortable-table">
      <thead>
        <tr>
          <th>#</th><th>Issue</th><th>Reviews</th><th>Avg rating</th>
          <th>Trend</th><th>Priority</th>
        </tr>
      </thead>
      <tbody>
        {% for issue in issues %}
        <tr>
          <td>{{ issue.rank }}</td>
          <td><a href="#issue-{{ issue.rank }}">{{ issue.label }}</a></td>
          <td>{{ issue.count }}</td>
          <td>{{ "%.1f"|format(issue.avg_rating) }}</td>
          <td>
            {% set t = issue.trend %}
            {% if t and t.classification == "escalating" %}
              <span class="trend trend-up" title="escalating since prior run">▲ +{{ "%.0f"|format(t.pct_change) }}%</span>
            {% elif t and t.classification == "improving" %}
              <span class="trend trend-down" title="improving since prior run">▼ {{ "%.0f"|format(t.pct_change) }}%</span>
            {% elif t and t.classification == "new" %}
              <span class="trend trend-new" title="new this run, no prior match">✦ new</span>
            {% elif t and t.classification == "stable" %}
              <span class="trend trend-stable" title="no significant change">— stable</span>
            {% else %}
              <span class="trend trend-none" title="no comparison data">—</span>
            {% endif %}
          </td>
          <td>{{ "%.2f"|format(issue.score) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>

    {# Render a card. Pulled into a Jinja macro so the same markup is used
       for the prominent top-3 and the collapsed 4-5. Phase VII v2: quieter
       layout, no H4 subheadings, representative quotes lead, secondary
       metrics compacted into a footer block at the bottom. #}
    {% macro issue_card(issue) %}
    <article class="issue-card" id="issue-{{ issue.rank }}">
      <h3>Issue {{ issue.rank }} — {{ issue.label }}</h3>
      {% if issue.label_is_llm %}
      <div class="subtitle">{{ issue.aspect_string }}</div>
      {% endif %}

      <div class="card-stats">
        <span class="big-number">{{ "{:,}".format(issue.count) }}<small>reviews</small></span>
        <span>{{ "%.1f"|format(issue.avg_rating) }}★ avg</span>
        <span class="sep">·</span>
        <span>priority {{ "%.2f"|format(issue.score) }}</span>
      </div>

      {% if issue.sparkline %}
      <div class="sparkline-wrap"><canvas data-sparkline="{{ issue.rank - 1 }}"></canvas></div>
      <div class="sparkline-axis">
        <span>{{ issue.sparkline.earliest }}</span>
        <span>{{ issue.sparkline.latest }}</span>
      </div>
      {% endif %}

      {% if issue.representative_reviews %}
      <div class="quotes">
        <div class="quotes-intro">In their words</div>
        {% for r in issue.representative_reviews %}
        <blockquote>{{ r }}</blockquote>
        {% endfor %}
      </div>
      {% endif %}

      <div class="metrics-footer">
        <div class="metric-row">
          <span class="metric-label">Type</span>
          <div class="stacked-bar split-bar">
            {% if issue.bug_complaint.obj_count %}<div style="background:#d9534f; flex: {{ issue.bug_complaint.obj_count }}" title="{{ issue.bug_complaint.obj_count }} bug-like reviews">
              {% if issue.bug_complaint.obj_share >= 0.15 %}{{ "%.0f"|format(issue.bug_complaint.obj_share * 100) }}% bugs{% endif %}
            </div>{% endif %}
            {% if issue.bug_complaint.subj_count %}<div style="background:#f0ad4e; flex: {{ issue.bug_complaint.subj_count }}" title="{{ issue.bug_complaint.subj_count }} complaint-like reviews">
              {% if issue.bug_complaint.subj_share >= 0.15 %}{{ "%.0f"|format(issue.bug_complaint.subj_share * 100) }}% complaints{% endif %}
            </div>{% endif %}
          </div>
        </div>

        {% if issue.emotions %}
        <div class="metric-row">
          <span class="metric-label">Emotions</span>
          {% for e in issue.emotions[:4] %}
            <span class="pill">{{ e.label }} {{ "%.0f"|format(e.share * 100) }}%</span>
          {% endfor %}
        </div>
        {% endif %}

        {% if issue.entities %}
        <div class="metric-row">
          <span class="metric-label">Mentions</span>
          {% for ent in issue.entities %}
            <span class="pill">{{ ent.text }} ×{{ ent.count }}</span>
          {% endfor %}
        </div>
        {% endif %}

        {% if issue.app_versions %}
        <div class="metric-row">
          <span class="metric-label">App versions</span>
          {% for v in issue.app_versions %}
            <span class="pill">{{ v.version }} ×{{ v.count }}</span>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </article>
    {% endmacro %}

    {% for issue in issues[:3] %}
      {{ issue_card(issue) }}
    {% endfor %}

    {% if issues|length > 3 %}
    <details class="more-issues">
      <summary>Show {{ issues|length - 3 }} more priority issue{{ "s" if (issues|length - 3) != 1 else "" }}</summary>
      {% for issue in issues[3:] %}
        {{ issue_card(issue) }}
      {% endfor %}
    </details>
    {% endif %}
    {% else %}
    <p><em>No negative-leaning clusters detected.</em></p>
    {% endif %}
  </section>

  <!-- Detailed analysis (Phase IX). The global Most Urgent Reviews,
       Emotion Distribution, Mentioned Entities, and Aspect Index tables
       were dropped — their per-issue equivalents inside the cards above
       carry the useful signal, the global aggregates were noise. The
       Overall Sentiment 6-card grid is condensed into the "By the numbers"
       footer at the end. What remains is counter-signal not visible
       elsewhere: positives clusters, and ABSA's loved/hated view. Each
       gets a one-sentence LLM lead in place of a data-only table dump. -->
  <hr class="detailed-divider">
  <section id="detailed">
    <h2>Detailed analysis</h2>

    {% if positives.entries %}
    <h3>What are users happy about?</h3>
    {% if positives.narrative %}
    <p class="section-narrative">{{ positives.narrative | bold_md_to_html | safe }}</p>
    {% endif %}
    <table class="sortable-table">
      <thead>
        <tr><th>Theme</th><th>Top aspects</th><th>Reviews</th><th>Avg rating</th></tr>
      </thead>
      <tbody>
      {% for p in positives.entries %}
        <tr>
          <td>{{ p.cluster_id }}</td>
          <td>{{ p.label }}</td>
          <td>{{ p.count }}</td>
          <td>{{ "%.1f"|format(p.avg_rating) }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}

    {% if absa.loved or absa.hated %}
    <h3>Which features are loved vs hated?</h3>
    {% if absa.narrative %}
    <p class="section-narrative">{{ absa.narrative | bold_md_to_html | safe }}</p>
    {% endif %}

    {% if absa.loved %}
    <h4>Loved</h4>
    {% set max_loved = (absa.loved | map(attribute='avg_polarity') | max) %}
    {% for it in absa.loved %}
    <div class="absa-bar-row">
      <span>{{ it.aspect }}</span>
      <div class="absa-bar loved" style="width: {{ ((it.avg_polarity / max_loved) * 100) }}%"
           title="avg polarity {{ "%+.2f"|format(it.avg_polarity) }}">+{{ "%.2f"|format(it.avg_polarity) }}</div>
      <span>{{ it.count }} mentions</span>
    </div>
    {% endfor %}
    {% endif %}

    {% if absa.hated %}
    <h4>Hated</h4>
    {% set min_hated = (absa.hated | map(attribute='avg_polarity') | min) %}
    {% for it in absa.hated %}
    <div class="absa-bar-row">
      <span>{{ it.aspect }}</span>
      <div class="absa-bar hated" style="width: {{ ((it.avg_polarity / min_hated) * 100) }}%"
           title="avg polarity {{ "%+.2f"|format(it.avg_polarity) }}">{{ "%.2f"|format(it.avg_polarity) }}</div>
      <span>{{ it.count }} mentions</span>
    </div>
    {% endfor %}
    {% endif %}
    {% endif %}
  </section>

  <!-- By the numbers — Phase IX one-line stats footer. Replaces the
       multi-bullet Feature Summary that used to close the report and the
       6-card Overall Sentiment grid that used to lead Detailed Analysis. -->
  <footer class="by-the-numbers">
    <p>
      <strong>By the numbers:</strong>
      {{ "{:,}".format(feature_summary.n_reviews) }} reviews ·
      {{ "%.2f"|format(overall.avg_rating) }}★ avg ·
      {{ "%+.2f"|format(overall.avg_polarity) }} polarity ·
      {{ "%.0f"|format(overall.neg_pct * 100) }}% negative
      ({{ "%.0f"|format(overall.obj_neg_pct * 100) }}% bug-shaped,
       {{ "%.0f"|format(overall.subj_neg_pct * 100) }}% emotional) ·
      {{ "{:,}".format(feature_summary.unique_aspects) }} aspects ·
      {{ feature_summary.themes }} topics ·
      {{ feature_summary.n_issues }} priority issues
    </p>
  </footer>
</main>

<script>{{ chart_js | safe }}</script>
<script id="report-data" type="application/json">{{ report_data | tojson }}</script>
<script>
  const reportData = JSON.parse(document.getElementById('report-data').textContent);

  // -- Sparklines (Chart.js) ---------------------------------------------
  // Parse "YYYY-MM-DD" as local-tz dates so labels don't show off-by-one
  // for west-of-UTC viewers (default `new Date(s)` parses ISO as UTC).
  function parseISODate(s) {
    const [y, m, d] = s.split('-').map(Number);
    return new Date(y, m - 1, d);
  }
  function fmtShort(d) {
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }
  // Compute a bucket's date range "Feb 12 – Mar 5" given the chart's overall
  // span and number of buckets. Used in tooltips so each bar is grounded
  // in real time.
  function bucketDateLabel(idx, total, earliestStr, latestStr) {
    const start = parseISODate(earliestStr);
    const end = parseISODate(latestStr);
    const spanMs = end - start;
    const bucketMs = spanMs / total;
    const bucketStart = new Date(start.getTime() + bucketMs * idx);
    const bucketEnd = new Date(start.getTime() + bucketMs * (idx + 1));
    return `${fmtShort(bucketStart)} – ${fmtShort(bucketEnd)}`;
  }

  reportData.issues.forEach((issue, idx) => {
    if (!issue.sparkline) return;
    const canvas = document.querySelector(`canvas[data-sparkline="${idx}"]`);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const sp = issue.sparkline;
    const labels = sp.buckets.map((_, i) =>
      bucketDateLabel(i, sp.buckets.length, sp.earliest, sp.latest)
    );
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          data: sp.buckets,
          backgroundColor: '#3b82f6',
          borderRadius: 2,
          barThickness: 'flex',
          maxBarThickness: 40,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 0 },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              // `label` is the bucket date range (set above);
              // surface it as the title so the tooltip leads with "when".
              title: (items) => items[0].label,
              label: (item) => `${item.parsed.y} mention${item.parsed.y === 1 ? '' : 's'}`,
            },
          },
        },
        scales: {
          x: { display: false },
          y: { beginAtZero: true, ticks: { precision: 0 } },
        },
      },
    });
  });

  // -- Sortable tables ---------------------------------------------------
  document.querySelectorAll('.sortable-table').forEach(table => {
    const headers = Array.from(table.querySelectorAll('thead th'));
    headers.forEach((th, idx) => {
      th.addEventListener('click', () => {
        const tbody = table.querySelector('tbody');
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const wasAsc = th.classList.contains('sort-asc');
        headers.forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
        th.classList.add(wasAsc ? 'sort-desc' : 'sort-asc');
        const dir = wasAsc ? -1 : 1;
        rows.sort((a, b) => {
          const aText = a.cells[idx].textContent.trim();
          const bText = b.cells[idx].textContent.trim();
          // Try numeric comparison first
          const aNum = parseFloat(aText.replace(/[%,]/g, ''));
          const bNum = parseFloat(bText.replace(/[%,]/g, ''));
          if (!isNaN(aNum) && !isNaN(bNum)) return (aNum - bNum) * dir;
          return aText.localeCompare(bText) * dir;
        });
        rows.forEach(r => tbody.appendChild(r));
      });
    });
  });

  // -- Aspect index filter -----------------------------------------------
  const aspectFilter = document.getElementById('aspect-filter');
  if (aspectFilter) {
    aspectFilter.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      const rows = document.querySelectorAll('#aspect-index-table tbody tr');
      rows.forEach(row => {
        const aspect = row.cells[0].textContent.toLowerCase();
        row.style.display = !q || aspect.includes(q) ? '' : 'none';
      });
    });
  }

  // -- Theme toggle ------------------------------------------------------
  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme') || 'auto';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('report-theme', next); } catch (e) { /* ignore */ }
  }
  try {
    const saved = localStorage.getItem('report-theme');
    if (saved) document.documentElement.setAttribute('data-theme', saved);
  } catch (e) { /* ignore */ }
</script>
</body>
</html>
